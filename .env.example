# Copy this file to .env.local and fill in your actual keys.
# .env.local is gitignored — never commit real keys.

# Backend datasource/cache
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ling_ai_code_generation
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_DATABASE=0

# Frontend origins allowed to call the credentialed backend API.
# For Spring env vars, comma-separated values bind to a list.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Main model/image provider keys
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
OPENAI_API_KEY=
PEXELS_API_KEY=

# Review provider: zhipu (default), openai, or fallback-deepseek.
REVIEW_MODEL_PROVIDER=zhipu

# New multi-agent orchestrator flag. Keep false in prod until explicitly validated.
AGENT_ORCHESTRATOR_ENABLED=false
